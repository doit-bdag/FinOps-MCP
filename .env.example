# Transport: "stdio" (local) or "streamable-http" (Cloud Run)
MCP_TRANSPORT=stdio

# Google Cloud
GCP_PROJECT_ID=bdag-playground
GCP_LOCATION=us-west1

# Firestore
FIRESTORE_COLLECTION=finops_chunks

# Local dev only — Cloud Run uses Workload Identity instead
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Crawl settings
CRAWL_MAX_DEPTH=3
CRAWL_CONCURRENT_PAGES=5
CRAWL_DELAY_MS=500

# Cloud Run sets this automatically
PORT=8080
